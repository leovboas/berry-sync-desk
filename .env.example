# ── Supabase ──────────────────────────────────────────────────────────────────
# URL do projeto Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave pública (anon) — segura para expor no client
SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# ID do projeto (usado em alguns helpers do Supabase)
VITE_SUPABASE_PROJECT_ID=SEU_PROJETO_ID

# Chave de service role — NUNCA exponha no client, apenas server-side
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Railway (preenchido automaticamente) ──────────────────────────────────────
# PORT é setado pelo Railway — não precisa configurar
# RAILWAY_ENVIRONMENT é setado pelo Railway — ativa o preset Node.js no build
